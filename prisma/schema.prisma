generator client {
  provider = "prisma-client"
  output   = "../src/lib/server/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUBMITTER
  MODERATOR
}

enum FieldType {
  TEXT
  SELECT
  FILE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(uuid())
  name      String
  publicKey String?  // Null until first MODERATOR claims the project and generates the keypair
  createdAt DateTime @default(now())

  memberships Membership[]
  submissions Submission[]
  formFields  FormField[]
  inviteLinks InviteLink[]
}

model User {
  id                  String   @id @default(uuid())
  signingPublicKey    String   @unique  // ECDSA P-256 JWK — used for challenge-response auth and submission signatures
  encryptionPublicKey String   @unique  // ECDH P-256 JWK — used for hybrid encryption of symmetric keys
  encryptedName       String            // Encrypted with project public key
  encryptedContact    String            // Encrypted with project public key
  createdAt           DateTime @default(now())

  memberships Membership[]
  sessions    Session[]
  submissions Submission[]
  inviteLinks InviteLink[] // Links created by this user
}

model Membership {
  userId                     String
  projectId                  String
  role                       Role
  encryptedProjectPrivateKey String?  // Non-null for MODERATORs. Encrypted with the user's public key.
  joinedAt                   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  nonce     String   @id  // Random nonce issued to client. Single-use, short TTL.
  expiresAt DateTime
}

model InviteLink {
  id               String    @id @default(uuid())
  token            String    @unique
  projectId        String
  createdBy        String?   // Null for admin-generated links
  creatorSignature String?   // Null for admin-generated links
  role             Role
  maxUses          Int?      // Null = unlimited
  usedCount        Int       @default(0)
  expiresAt        DateTime? // Null = no expiry
  createdAt        DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)
}

model Submission {
  id                 String   @id @default(uuid())
  projectId          String
  userId             String
  encryptedPayload   String   // AES-GCM ciphertext of form data (JSON)
  encryptedKeyProject String  // Symmetric key encrypted with project public key
  encryptedKeyUser   String   // Symmetric key encrypted with submitter's public key
  submitterSignature String   // Signature over (nonce || SHA-256(encryptedPayload))
  createdAt          DateTime @default(now())

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  files   SubmissionFile[]
}

model SubmissionFile {
  id               String   @id @default(uuid())
  submissionId     String
  fieldName        String
  storagePath      String   // Path to encrypted file on disk
  encryptedKey     String   // Symmetric key encrypted with project public key
  encryptedKeyUser String   // Symmetric key encrypted with submitter's public key
  sizeBytes        Int
  createdAt        DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model FormField {
  id        String    @id @default(uuid())
  projectId String
  label     String
  type      FieldType
  options   String?   // JSON-encoded string array, used for SELECT fields
  required  Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
