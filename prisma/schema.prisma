generator client {
  provider = "prisma-client"
  output   = "../src/lib/server/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUBMITTER
  MODERATOR
}

enum FieldType {
  TEXT
  SELECT
  FILE
  DATE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(uuid())
  name      String
  publicKey String?  // Null until first MODERATOR claims the project and generates the keypair
  createdAt DateTime @default(now())

  members     Member[]
  submissions Submission[]
  formFields  FormField[]
  inviteLinks InviteLink[]
}

// Each project membership is an independent cryptographic identity.
// A single physical person joining N projects produces N unlinked Member rows.
model Member {
  id                         String   @id @default(uuid())
  projectId                  String
  signingPublicKey           String   @unique
  encryptionPublicKey        String   @unique
  encryptedName              String   // Encrypted with project public key
  encryptedContact           String   // Encrypted with project public key
  role                       Role
  encryptedProjectPrivateKey String?  // Non-null for MODERATORs
  joinedAt                   DateTime @default(now())

  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions    Session[]
  submissions Submission[]
  inviteLinks InviteLink[]
}

model Session {
  id        String   @id @default(uuid())
  memberId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Challenge {
  nonce     String   @id  // Random nonce issued to client. Single-use, short TTL.
  expiresAt DateTime
}

model InviteLink {
  id               String    @id @default(uuid())
  token            String    @unique
  projectId        String
  createdByMember  String?   // Null for admin-generated links
  creatorSignature String?   // Null for admin-generated links
  role             Role
  maxUses          Int?      // Null = unlimited
  usedCount        Int       @default(0)
  expiresAt        DateTime? // Null = no expiry
  createdAt        DateTime  @default(now())

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creatorMember Member? @relation(fields: [createdByMember], references: [id], onDelete: SetNull)
}

model Submission {
  id                   String   @id @default(uuid())
  projectId            String
  memberId             String
  // Legacy plaintext fields (schema v1). Null once the client has migrated to v2.
  type                 String?
  archiveCandidateUrl  String?
  archiveUrl           String?
  // schemaVersion=1: payload is flat Record<string,string>, metadata in plaintext columns above.
  // schemaVersion=2: payload is DecryptedPayload envelope, plaintext columns are null.
  schemaVersion        Int      @default(1)
  encryptedPayload     String   // AES-GCM ciphertext of DecryptedPayload JSON (v2) or flat fields (v1)
  encryptedKeyProject  String   // Symmetric key encrypted with project public key
  encryptedKeyUser     String   // Symmetric key encrypted with submitter's public key
  submitterSignature   String   // Signature over (nonce || SHA-256(encryptedPayload))
  createdAt            DateTime @default(now())

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  files   SubmissionFile[]
}

model SubmissionFile {
  id               String   @id @default(uuid())
  submissionId     String
  fieldName        String
  // Legacy plaintext field (schema v1). Null once the client has migrated to v2.
  mimeType         String?
  // schemaVersion=1: encryptedMeta is null, mimeType has the value.
  // schemaVersion=2: encryptedMeta holds AES-GCM ciphertext of { mimeType }, mimeType is null.
  schemaVersion    Int      @default(1)
  encryptedMeta    String?  // AES-GCM ciphertext of { mimeType } encrypted with per-file symmetric key
  storagePath      String   // Path to encrypted file on disk
  encryptedKey     String   // Symmetric key encrypted with project public key
  encryptedKeyUser String   // Symmetric key encrypted with submitter's public key
  sizeBytes        Int
  createdAt        DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model FormField {
  id        String    @id @default(uuid())
  projectId String
  label     String
  type      FieldType
  options   String?   // JSON-encoded string array, used for SELECT fields
  required  Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
