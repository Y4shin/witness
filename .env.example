# Public URL used for CSRF protection, absolute redirects, and OIDC callback URLs.
ORIGIN=http://localhost:3000

# Database
# Path to the SQLite database file (libsql/Turso URL also accepted).
DATABASE_URL=file:./reporting-tool.db

# Admin console
# Choose exactly one admin auth mode:
# - Password mode: keep ADMIN_AUTH_MODE=password, set ADMIN_PASSWORD, leave ADMIN_OIDC_* blank.
# - OIDC mode: set ADMIN_AUTH_MODE=oidc, leave ADMIN_PASSWORD blank, and fill in ADMIN_OIDC_*.
ADMIN_AUTH_MODE=password
ADMIN_PASSWORD=change-me-to-a-strong-password

# OIDC/OAuth 2.0 admin login
# ADMIN_OIDC_DISCOVERY_URL should point to the provider discovery endpoint root.
# For authentik this is typically:
#   http://localhost:9000/application/o/reporting-tool/
ADMIN_OIDC_DISCOVERY_URL=
ADMIN_OIDC_CLIENT_ID=
ADMIN_OIDC_CLIENT_SECRET=
ADMIN_OIDC_SCOPES=openid profile email

# Authorize admins by verified email, subject claim, and/or group claim.
# At least one must be set in OIDC mode. Ensure your provider exposes `groups`
# in the ID token or userinfo response if you use group-based authorization.
ADMIN_OIDC_ALLOWED_EMAILS=admin@example.com
# ADMIN_OIDC_ALLOWED_SUBJECTS=01234567-89ab-cdef-0123-456789abcdef
# ADMIN_OIDC_ALLOWED_GROUPS=reporting-tool-admin-access

# Session
# Secret used to sign session tokens. Must be at least 32 random bytes (hex).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-64-hex-chars

# Authentik test stack (optional, used with `docker compose --profile oidc up`)
AUTHENTIK_TAG=2026.2.1
AUTHENTIK_HTTP_PORT=9000
AUTHENTIK_HTTPS_PORT=9443
AUTHENTIK_POSTGRES_DB=authentik
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=change-me-authentik-db-password
AUTHENTIK_SECRET_KEY=change-me-authentik-secret-key
AUTHENTIK_BOOTSTRAP_EMAIL=akadmin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me-authentik-admin-password
AUTHENTIK_BOOTSTRAP_TOKEN=change-me-authentik-api-token
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# OpenTelemetry (optional)
# Set OTEL_ENABLED=true to activate tracing, metrics, and structured log forwarding.
OTEL_ENABLED=false

# Human-readable service name shown in traces and logs.
OTEL_SERVICE_NAME=reporting-tool

# OTLP/HTTP collector endpoint (required when OTEL_ENABLED=true).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# File storage (optional; defaults to local filesystem ./uploads/)
# Set all four S3_* variables to use S3-compatible object storage instead.
#
# Hetzner example:
#   S3_ENDPOINT=https://fsn1.your-objectstorage.com
#   S3_BUCKET=my-witness-files
#   S3_REGION=eu-central
#
# S3_ENDPOINT=https://<region>.your-objectstorage.com
# S3_BUCKET=my-bucket
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_REGION=auto

# App version displayed in the UI.
# Injected automatically at build time via the PUBLIC_VERSION Docker build-arg.
PUBLIC_VERSION=

# Logging
# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to true for pretty-printed human-readable output (development only).
LOG_PRETTY=false
