# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (libsql/turso URL also accepted).
DATABASE_URL=file:./reporting-tool.db

# ── Admin console ─────────────────────────────────────────────────────────────
# Password for the /admin route. Keep this secret and at least 16 characters.
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Session ───────────────────────────────────────────────────────────────────
# Secret used to sign session tokens. Must be at least 32 random bytes (hex).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-64-hex-chars

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
# Set OTEL_ENABLED=true to activate tracing, metrics, and structured log forwarding.
# When false (default) the instrumentation module is a no-op — no network calls.
OTEL_ENABLED=false

# Human-readable service name shown in traces and logs.
OTEL_SERVICE_NAME=reporting-tool

# OTLP/HTTP collector endpoint (e.g. a local OpenTelemetry Collector or Grafana Agent).
# Required when OTEL_ENABLED=true.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Logging ───────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to true for pretty-printed human-readable output (development only).
LOG_PRETTY=false
